{
  "name": "prysma",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run vite-dev\" \"node server.js\"",
    "desktop": "electron electron/main.mjs",
    "desktop:build": "npm run build && electron-builder --dir",
    "desktop:portable": "npm run build && electron-builder --win portable",
    "mobile:build": "npm run build",
    "mobile:sync": "npm run mobile:build && npx cap sync",
    "mobile:android:add": "npx cap add android",
    "mobile:android:sync": "npm run mobile:build && npx cap sync android",
    "mobile:android:open": "npx cap open android",
    "vite-dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.14.0",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@capacitor/cli": "^7.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^30.5.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.prysma.app",
    "productName": "Prysma",
    "directories": {
      "buildResources": "build-assets",
      "output": "release"
    },
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "files": [
      "dist/**/*",
      "build-assets/**/*",
      "public/app-icon.png",
      "public/app-icon_final.png",
      "electron/**/*",
      "public/images/**/*",
      "server.js",
      "src/data/manual.json",
      "package.json"
    ],
    "win": {
      "icon": "build-assets/app-icon_final.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
